{
	"name": "main",
	"image": "nwpackageversions:main",
	"initializeCommand": "docker build -f .devcontainer/main/Dockerfile -t nwpackageversions:main .",
	"runArgs": ["--name", "nwpackageversions-main"],
	"containerEnv": {
		"TZ": "Europe/Stockholm",
		"DEVCONTAINER_NAME": "main",
		"PYTHONPYCACHEPREFIX": "/home/vscode/.cache/pycache",
		"MYPY_CACHE_DIR": "/home/vscode/.cache/mypy_cache"
	},
	"customizations": {
		"vscode": {
			"settings": {},
			"extensions": [
				"ms-python.python",
				"ms-python.vscode-pylance",
				"shd101wyy.markdown-preview-enhanced"
			]
		}
	},
	"mounts": [
		"source=nwpackageversions-cache,target=/home/vscode/.cache,type=volume"
	]
}